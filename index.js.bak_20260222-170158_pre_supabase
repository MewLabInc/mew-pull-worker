import express from "express";
import { PubSub } from "@google-cloud/pubsub";

const BUILD_ID = process.env.BUILD_ID || process.env.BUILD_TAG || "no-build-id";

let IS_READY = false;

function jlog(event, data = {}) {
  const payload = {
    event,
    ts: new Date().toISOString(),
    build_id: BUILD_ID,
    service: process.env.K_SERVICE,
    revision: process.env.K_REVISION,
    ...data,
  };
  console.log(JSON.stringify(payload));
}

const stats = {
  startedAt: new Date().toISOString(),
  buildId: BUILD_ID,
  projectId: null,
  subPath: null,
  subStartedAt: null,
  recv: 0,
  acked: 0,
  nacked: 0,
  lastMsgId: null,
  lastRaw: null,
  lastErr: null,
};

function setErr(err) {
  stats.lastErr = err?.message || String(err);
}

process.on("unhandledRejection", (err) => setErr(err));
process.on("uncaughtException", (err) => setErr(err));

const app = express();

// Always stamp responses so we can prove which build served it
app.use((_req, res, next) => {
  res.setHeader("x-mew-build-id", BUILD_ID);
  next();
});

app.get("/", (_req, res) => res.status(200).send("ok"));
app.get("/health", (_req, res) => res.status(200).send("ok"));
app.get("/healthz", (_req, res) => res.status(200).send("ok"));
app.get("/readyz", (_req, res) =>
  res.status(IS_READY ? 200 : 503).send(IS_READY ? "ready" : "not-ready")
);
app.get("/debug", (_req, res) => res.status(200).json(stats));

// ---- Pub/Sub pull subscriber ----
const PROJECT_ID =
  process.env.PUBSUB_PROJECT ||
  process.env.GOOGLE_CLOUD_PROJECT ||
  process.env.GCP_PROJECT ||
  "mew-prod-488113";

const SUB_RAW = process.env.PUBSUB_SUB_FOOD || "food-ingest-sub";
const SUB_PATH = SUB_RAW.startsWith("projects/")
  ? SUB_RAW
  : `projects/${PROJECT_ID}/subscriptions/${SUB_RAW}`;

stats.projectId = PROJECT_ID;
stats.subPath = SUB_PATH;

const MAX_MESSAGES = Number(process.env.MAX_MESSAGES || "5");

const pubsub = new PubSub({ projectId: PROJECT_ID });
let sub;

function startSubscription(subPath) {
  stats.subStartedAt = new Date().toISOString();

  sub = pubsub.subscription(subPath, {
    flowControl: { maxMessages: MAX_MESSAGES, allowExcessMessages: false },
  });

  sub.on("error", (err) => {
    setErr(err);
    jlog("pubsub_error_listener", { err: stats.lastErr });
  });

  sub.on("message", (m) => {
    const msgId = m.id;
    jlog("pubsub_recv", { msgId, sub: SUB_PATH });

    try {
      const raw = m.data ? m.data.toString("utf8") : "";
      stats.recv += 1;
      stats.lastMsgId = msgId;
      stats.lastRaw = raw;

      m.ack();
      stats.acked += 1;

      jlog("pubsub_acked", { msgId });
    } catch (e) {
      setErr(e);
      stats.nacked += 1;

      jlog("pubsub_error", { msgId, err: stats.lastErr });

      try { m.nack(); } catch {}
    }
  });

  IS_READY = true;
  jlog("ready", { sub: SUB_PATH, maxMessages: MAX_MESSAGES });
}

jlog("startup", { sub: SUB_PATH, build: BUILD_ID });
startSubscription(SUB_PATH);

async function gracefulShutdown(signal) {
  // stderr is more reliable during shutdown
  console.error("shutdown_signal signal=" + signal);
  jlog("shutdown_signal", { signal });

  // Stop receiving new messages immediately
  try {
    if (sub) {
      sub.removeAllListeners("message");
      sub.removeAllListeners("error");
    }
  } catch (e) {
    console.error("shutdown_listener_cleanup_error err=" + (e?.message || String(e)));
    jlog("shutdown_listener_cleanup_error", { err: e?.message || String(e) });
  }

  if (typeof server?.close === "function") {
    console.error("closing_http_server");
    await new Promise((resolve) => server.close(resolve));
    console.error("http_server_closed");
    jlog("http_server_closed");
  }

  if (sub) {
    console.error("closing_pubsub_subscription");
    try {
      await Promise.race([
        sub.close(),
        new Promise((_, rej) => setTimeout(() => rej(new Error("sub_close_timeout")), 5000)),
      ]);
      console.error("pubsub_subscription_closed");
      jlog("pubsub_subscription_closed");
    } catch (err) {
      console.error("error_closing_pubsub_subscription err=" + (err?.message || String(err)));
      jlog("error_closing_pubsub_subscription", { err: err?.message || String(err) });
    }
  }

  // Give logs a moment to flush
  await new Promise((r) => setTimeout(r, 500));
  process.exit(0);
}

process.on("SIGINT", gracefulShutdown);
process.on("SIGTERM", gracefulShutdown);

const port = process.env.PORT || 8080;
const server = app.listen(port, () => {
  jlog("http_listening", { port });
});
